# ==============================================================================
# Smart Leads CRM Dashboard - Consolidated Environment Template
# ==============================================================================
# Copy the variables below into their respective local directories.
# Or configure them when deploying to a cloud hosting platform (e.g. Render, Railway, Vercel).

# ------------------------------------------------------------------------------
# 1. Backend Environment Setup (Place in: /backend/.env)
# ------------------------------------------------------------------------------

# The port where the Express.js server runs locally
PORT=5000

# MongoDB Connection String (Local MongoDB instance or MongoDB Atlas URI)
MONGODB_URI=mongodb://localhost:27017/smartleads

# JSON Web Token (JWT) Configuration
# Choose a strong secret string for local development and a highly secure one for production
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Environment Mode ('development' or 'production')
NODE_ENV=development

# Allowed CORS Origin (The URL of your frontend application)
CORS_ORIGIN=http://localhost:5173

# ------------------------------------------------------------------------------
# 2. Frontend Environment Setup (Place in: /frontend/.env)
# ------------------------------------------------------------------------------

# The URL pointing to the Backend API base.
# Vite serves variables prefixed with VITE_ to the client bundle.
VITE_API_BASE_URL=http://localhost:5000/api
